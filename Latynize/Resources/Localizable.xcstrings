    "Latynize — Kazakh Script Converter\nAll processing happens on-device. No data leaves your phone." : {
      "localizations" : {
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latynize — Қазақ жазуын түрлендіруші\\nБарлығы құрылғыда өңделеді. Деректер жіберілмейді."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Latynize — Конвертер казахской письменности\\nВсё обрабатывается на устройстве. Данные не передаются."
          }
        }
      }
    },
